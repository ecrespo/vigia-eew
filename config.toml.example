# config.toml.example — Vigía-eew
# Copia este archivo como `config.toml` en el directorio de config del usuario
# (o pásalo con `vigia-eew --config <ruta>`). Todos los valores tienen defaults
# sensatos centrados en Caracas; ajusta a tu zona.

# Punto geográfico contra el que se calculan distancia y radio (RF-12). Si **borras o
# comentas** esta sección completa, el agente detecta tu ubicación automáticamente por IP
# en el primer arranque y la cachea para no repetir la consulta después (RF-33, ver
# docs/API-SPEC.md §4). Déjala como está (o ajústala) para fijar tu ubicación a mano.
[referencia]
nombre = "Caracas"
lat = 10.4806
lon = -66.9036

[filtro]
radio_km = 300.0
# Magnitud mínima para que un sismo dispare una alerta (RF-12). Sube este valor si no
# quieres que se reporten sismos menores; por ejemplo, para ignorar todo lo < 3.0:
# magnitud_minima = 3.0
magnitud_minima = 2.5

[fuentes.emsc]
habilitado = true
url = "wss://www.seismicportal.eu/standing_order/websocket"
ping_interval_s = 15      # keepalive obligatorio (RF-02)
ping_timeout_s = 20
backoff_max_s = 60        # tope del backoff exponencial de reconexión (RF-03)

[fuentes.usgs]
habilitado = true
url = "https://earthquake.usgs.gov/fdsnws/event/1/query"
intervalo_poll_s = 60     # respaldo de baja frecuencia (RF-05)
timeout_s = 15

[dedup]
distancia_km = 100.0      # mismo sismo si <= 100 km, <= 90 s y <= 0.5 mag (RF-09)
ventana_s = 90
delta_magnitud = 0.5

[severidad]
# Límite superior de cada nivel; por encima de atencion_max es "critico" (RF-13).
info_max = 4.0
atencion_max = 5.5

[notificacion]
pantalla_completa = false
zona_horaria = "America/Caracas"
sonido = true

[logging]
nivel = "INFO"
archivo = "vigia-eew.log"
max_bytes = 1048576
backups = 3

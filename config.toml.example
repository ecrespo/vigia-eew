# config.toml.example — Vigía-eew
# Copy this file as `config.toml` in the user's config directory
# (or pass it with `vigia-eew --config <path>`). All values have sensible
# defaults centered on Caracas; adjust to your area.

# Geographic point used to calculate distance and radius (RF-12). If you **delete or
# comment out** this whole section, the agent automatically detects your location by
# IP on first startup and caches it so the lookup isn't repeated (RF-33, see
# docs/API-SPEC.md §4). Leave it as-is (or adjust it) to set your location manually.
[reference]
name = "Caracas"
lat = 10.4806
lon = -66.9036

[filter]
radius_km = 300.0
# Minimum magnitude for an earthquake to trigger an alert (RF-12). Raise this value
# if you don't want smaller earthquakes reported; for example, to ignore anything < 3.0:
# min_magnitude = 3.0
min_magnitude = 2.5

[sources.emsc]
enabled = true
url = "wss://www.seismicportal.eu/standing_order/websocket"
ping_interval_s = 15      # mandatory keepalive (RF-02)
ping_timeout_s = 20
backoff_max_s = 60        # cap of the exponential reconnection backoff (RF-03)

[sources.usgs]
enabled = true
url = "https://earthquake.usgs.gov/fdsnws/event/1/query"
poll_interval_s = 60      # low-frequency backup (RF-05)
timeout_s = 15

[dedup]
distance_km = 100.0       # same earthquake if <= 100 km, <= 90 s, and <= 0.5 mag (RF-09)
window_s = 90
magnitude_delta = 0.5

[severity]
# Upper bound of each level; above warning_max is "critical" (RF-13).
info_max = 4.0
warning_max = 5.5

[notification]
fullscreen = false
timezone = "America/Caracas"
sound = true
# System tray icon (RF-34): status, pause/resume, edit config, quit.
# Best-effort — if the OS can't show it (e.g. GNOME/Wayland without the
# "AppIndicator and KStatusNotifierItem Support" extension), the agent keeps working.
tray_icon = true
# User-facing language (RF-35): "auto" detects it from the OS locale, falling back to
# English if unsupported. Set it explicitly to override: "en" or "es".
language = "auto"

[logging]
level = "INFO"
file = "vigia-eew.log"
max_bytes = 1048576
backups = 3
